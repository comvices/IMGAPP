{
  "entities": {
    "Activity": {
      "title": "Activity",
      "description": "A record of an activity with uploaded images",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Unique ID" },
        "activityName": { "type": "string", "description": "Name of the activity" },
        "learningArea": { 
          "type": "string", 
          "enum": [
            "ภาษาไทย",
            "คณิตศาสตร์",
            "วิทยาศาสตร์และเทคโนโลยี",
            "สังคมศึกษา ศาสนา และวัฒนธรรม",
            "สุขศึกษาและพลศึกษา",
            "ศิลปะ",
            "การงานอาชีพ",
            "ภาษาต่างประเทศ"
          ],
          "description": "One of the 8 learning areas" 
        },
        "uploaderName": { "type": "string", "description": "Name of the person who uploaded the image" },
        "description": { "type": "string", "description": "Details of the activity" },
        "imageUrls": { 
          "type": "array", 
          "items": { "type": "string" },
          "description": "List of URLs for uploaded images in the album" 
        },
        "createdAt": { "type": "string", "format": "date-time", "description": "Timestamp of creation" }
      },
      "required": ["activityName", "learningArea", "uploaderName", "imageUrls", "createdAt"]
    }
  },
  "firestore": {
    "/activities": {
      "schema": "Activity",
      "description": "Collection of activity records"
    }
  }
}
